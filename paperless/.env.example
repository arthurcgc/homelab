PAPERLESS_SECRET_KEY=change-me-to-a-long-random-string
PAPERLESS_TIME_ZONE=America/Sao_Paulo
PAPERLESS_OCR_LANGUAGE=por+eng
PAPERLESS_OCR_LANGUAGES=por
PAPERLESS_URL=http://pichau.local:8000
USERMAP_UID=1000
USERMAP_GID=1000
# macOS only: inotify doesn't cross the Colima/Docker Desktop bind-mount
# boundary, so paperless silently misses new files in consume/. Polling fixes it.
# PAPERLESS_CONSUMER_POLLING=30
